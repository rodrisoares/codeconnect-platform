# Copie para .env (cp .env.example .env) e ajuste os segredos.
# O docker-compose lê este arquivo automaticamente para substituir as variáveis.

# Segredos usados para assinar os tokens JWT. Gere valores aleatórios, ex.:
#   openssl rand -hex 32
JWT_SECRET=troque-este-segredo
JWT_REFRESH_SECRET=troque-este-segredo-refresh
